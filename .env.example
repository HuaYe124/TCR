# ==========================================
# TCR Environment Configuration
# ==========================================
# Copy this file to .env and fill in your values

# ---- HuggingFace ----
# Required: HuggingFace access token for model downloads
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# ---- Proxy Settings (optional) ----
# Uncomment and set if you need a proxy to access HuggingFace or other services
# HTTPS_PROXY=http://127.0.0.1:10809
# HTTP_PROXY=http://127.0.0.1:10809

# ---- Weights & Biases (optional) ----
# Uncomment if you want to enable experiment tracking
# WANDB_API_KEY=your_wandb_api_key_here
# WANDB_PROJECT=xrag-experiments
# WANDB_ENTITY=your_wandb_entity
# WANDB_MODE=online  # or "offline" for local-only
